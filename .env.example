# ============================================================
# 环境变量配置示例
# 使用方法：复制此文件为 .env，然后修改里面的值
#   cp .env.example .env
# ============================================================

# Flask 配置环境（development=开发 / production=生产）
FLASK_CONFIG=production

# 密钥（必须改！用下面的命令生成一个随机密钥）
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=在这里粘贴上面命令生成的随机字符串

# MySQL 数据库连接
# 格式：mysql+pymysql://用户名:密码@服务器地址:端口/数据库名?charset=utf8mb4
DATABASE_URL=mysql+pymysql://yiyou:your_password@localhost:3306/yiyou_factory?charset=utf8mb4
